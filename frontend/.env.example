# Dropbox Configuration
# Get your app key from: https://www.dropbox.com/developers/apps
VITE_DROPBOX_APP_KEY=your_dropbox_app_key_here

# Google Drive Configuration
# Get your credentials from: https://console.cloud.google.com/
# You'll need:
# - OAuth 2.0 Client ID (Web application type)
# - API Key (public key for the Picker API)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_GOOGLE_API_KEY=your_google_api_key_here

# Microsoft OneDrive Configuration
# Get your app ID from: https://portal.azure.com/
# Register your app in Azure AD and get the Application (client) ID
VITE_MICROSOFT_CLIENT_ID=your_microsoft_client_id_here

# Backend API URL — required for production builds when the API is on another host.
# For local `npm run dev`, leave unset so /api uses the Vite proxy (avoids CORS issues).
# VITE_API_URL=https://your-api.example.com

# Supabase Configuration (if using)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
